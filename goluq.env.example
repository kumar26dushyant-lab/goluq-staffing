# GoLuQ server config — copy to `.env` on the VM (NEVER commit .env).
#   cp goluq.env.example .env   &&   nano .env

HOST=127.0.0.1
PORT=8090

# Admin (protects /api/admin/*, /api/cron/*, and the /admin page). Invent a long random string.
ADMIN_SECRET=change-me-to-a-long-random-string

# Evolution API — on THIS box, so localhost works (no public URL needed).
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=your-evolution-api-key-from-wa_env_append
GOLUQ_WA_INSTANCE=goluq_main

# Owner number that receives new-lead WhatsApp alerts (10-digit or 91XXXXXXXXXX).
# Leave blank until the new GoLuQ number is connected.
OWNER_WHATSAPP=

# Gemini (optional — powers the smart chat + follow-up wording). Server-side only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
